# Dependencies
node_modules/

# Build output
dist/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.production

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Runtime temp folder (downloaded repos, extracted archives)
# These are generated at runtime by the ingestion pipeline — never commit
temp/downloads/*
temp/extracted/*
!temp/downloads/.gitkeep
!temp/extracted/.gitkeep
