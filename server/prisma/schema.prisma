generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Archon user — supports 3 auth providers
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?  // null for OAuth users
  
  // Auth provider info
  provider      String   @default("email") // "email" | "github" | "google"
  providerId    String?  // GitHub/Google user ID
  
  // Email verification
  emailVerified Boolean  @default(false)
  verifyToken   String?  @unique
  
  // GitHub-specific (for repo access)
  githubToken   String?
  githubLogin   String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([provider, providerId])
  @@index([verifyToken])
}
